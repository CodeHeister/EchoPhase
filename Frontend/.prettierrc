{
    "semi": true,
    "singleQuote": true,
    "tabWidth": 4,
    "useTabs": false,
    "printWidth": 80,
    "trailingComma": "es5",
    "arrowParens": "always",
    "overrides": [
        {
            "files": ["*.scss", "*.json"],
            "options": {
                "tabWidth": 2,
                "useTabs": false
            }
        }
    ]
}
