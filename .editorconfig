root = true

[*]
charset = utf-8
indent_style = space
indent_size = 4
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.cs]

indent_size = 4

max_line_length = 120

csharp_style_require_braces = true:suggestion

csharp_new_line_before_open_brace = all

csharp_style_var_when_type_is_apparent = true:suggestion

csharp_style_var_elsewhere = false:suggestion

dotnet_sort_system_directives_first = true

insert_final_newline = true

csharp_space_around_binary_operators = before_and_after

csharp_preserve_single_line_blocks = false

csharp_style_expression_bodied_properties = false:suggestion
csharp_style_expression_bodied_methods = never:suggestion

dotnet_remove_unnecessary_usings = true

dotnet_diagnostic.IDE0005.severity = warning  # unused using
dotnet_diagnostic.IDE0008.severity = none
dotnet_diagnostic.IDE0044.severity = suggestion  # readonly modifier where possible
dotnet_diagnostic.IDE0051.severity = warning  # unused private members
dotnet_diagnostic.IDE0290.severity = none
