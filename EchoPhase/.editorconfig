root = true

# Все файлы
[*]
charset = utf-8
indent_style = space
indent_size = 4
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

# C# файлы
[*.cs]

# Использовать 4 пробела для отступа
indent_size = 4

# Максимальная длина строки
max_line_length = 120

# Требовать фигурные скобки для всех блоков
csharp_style_require_braces = true:suggestion

# Выравнивание ключевых слов
csharp_new_line_before_open_brace = all

# Использовать var, когда тип очевиден
csharp_style_var_when_type_is_apparent = true:suggestion

# Использовать явный тип, когда тип не очевиден
csharp_style_var_elsewhere = false:suggestion

# Форматирование списков using - алфавитный порядок
dotnet_sort_system_directives_first = true

# Новая строка в конце файла
insert_final_newline = true

# Использовать пробелы вокруг бинарных операторов
csharp_space_around_binary_operators = before_and_after

# Выравнивание параметров метода
csharp_preserve_single_line_blocks = false

# Формат для expression-bodied членов
csharp_style_expression_bodied_methods = false:suggestion
csharp_style_expression_bodied_properties = false:suggestion

# Удаление неиспользуемых директив using
dotnet_remove_unnecessary_usings = true

# Правила анализатора стиля (можно менять severity: none, suggestion, warning, error)
dotnet_diagnostic.IDE0005.severity = warning  # unused using
dotnet_diagnostic.IDE0044.severity = suggestion  # readonly modifier where possible
dotnet_diagnostic.IDE0051.severity = warning  # unused private members
