{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Kestrel": {
	  "EndPoints": {
		"Http": {
		  "Url": "http://localhost:80"
		},
		"Https": {
		  "Url": "https://localhost:443",
		  "Certificate": {
			"Path": "Configurations/cert.pem",
			"KeyPath": "Configurations/key.pem"
		  }
		}
	  }
	},
	"Authentication": {
    "Schemes": {
      "Bearer": {
        "ValidAudiences": [
          "http://twitch.app",
          "https://twitch.app"
        ],
        "ValidIssuer": "TwtichApp"
      }
    }
  }
}
